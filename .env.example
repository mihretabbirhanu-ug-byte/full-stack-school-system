DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Optional but recommended for Prisma migrate commands (non-pooled Neon "direct" URL).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Used to sign the HttpOnly session cookie (set to a long random string)
AUTH_SECRET="replace-with-a-long-random-secret"

